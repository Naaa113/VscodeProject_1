{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentops-hub.local/contracts/schemas/common.v1.schema.json",
  "title": "AgentOps Hub Common Contract Schemas v1",
  "type": "object",
  "description": "Shared reusable shapes for tenant context, audit fields, pagination, errors, event envelopes, and tool envelopes.",
  "$defs": {
    "TenantContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tenant_id"],
      "properties": {
        "tenant_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "AuditFields": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_by", "created_at"],
      "properties": {
        "created_by": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_by": {
          "type": ["string", "null"]
        },
        "updated_at": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    },
    "TraceFields": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_id"],
      "properties": {
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "correlation_id": {
          "type": ["string", "null"]
        }
      }
    },
    "PageRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "page": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "page_size": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 20
        }
      }
    },
    "PageResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["page", "page_size", "total"],
      "properties": {
        "page": {
          "type": "integer",
          "minimum": 1
        },
        "page_size": {
          "type": "integer",
          "minimum": 1
        },
        "total": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "ErrorResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["error_code", "message", "trace_id", "retryable"],
      "properties": {
        "error_code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        },
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "retryable": {
          "type": "boolean"
        }
      }
    },
    "EventEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_id", "event_name", "event_version", "occurred_at", "tenant_id", "trace_id", "payload"],
      "properties": {
        "event_id": {
          "type": "string",
          "minLength": 1
        },
        "event_name": {
          "type": "string",
          "minLength": 1
        },
        "event_version": {
          "type": "string",
          "const": "v1"
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "tenant_id": {
          "type": "string",
          "minLength": 1
        },
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "producer": {
          "type": "string"
        },
        "consumers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "payload": {
          "type": "object"
        }
      }
    },
    "ToolRequestEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool_name", "tool_version", "tenant_id", "requested_by", "trace_id", "input"],
      "properties": {
        "tool_name": {
          "type": "string"
        },
        "tool_version": {
          "type": "string",
          "const": "v1"
        },
        "tenant_id": {
          "type": "string",
          "minLength": 1
        },
        "requested_by": {
          "type": "string",
          "minLength": 1
        },
        "idempotency_key": {
          "type": ["string", "null"]
        },
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "input": {
          "type": "object"
        }
      }
    },
    "ToolResponseEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool_name", "tool_version", "tenant_id", "trace_id", "status"],
      "properties": {
        "tool_name": {
          "type": "string"
        },
        "tool_version": {
          "type": "string",
          "const": "v1"
        },
        "tenant_id": {
          "type": "string",
          "minLength": 1
        },
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["success", "failed", "waiting_approval"]
        },
        "output": {
          "type": ["object", "null"]
        },
        "error": {
          "$ref": "#/$defs/ErrorResponse"
        },
        "audit": {
          "$ref": "#/$defs/AuditFields"
        }
      }
    }
  }
}
