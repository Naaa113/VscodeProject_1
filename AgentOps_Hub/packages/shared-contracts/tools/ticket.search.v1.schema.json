{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentops-hub.local/contracts/tools/ticket.search.v1.schema.json",
  "title": "ticket.search.v1",
  "type": "object",
  "x_tool": {
    "name": "ticket.search.v1",
    "version": "v1",
    "host": "ticket-service",
    "permission": "ticket:read",
    "requires_approval": false,
    "idempotency": "Not required for read-only search.",
    "timeout_ms": 3000,
    "retry": {"max_attempts": 2, "backoff_ms": 200},
    "audit_fields": ["tenant_id", "requested_by", "trace_id"]
  },
  "additionalProperties": false,
  "required": ["request", "response"],
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool_name", "tool_version", "tenant_id", "requested_by", "trace_id", "input"],
      "properties": {
        "tool_name": {"type": "string", "const": "ticket.search.v1"},
        "tool_version": {"type": "string", "const": "v1"},
        "tenant_id": {"type": "string"},
        "requested_by": {"type": "string"},
        "trace_id": {"type": "string"},
        "input": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "query": {"type": ["string", "null"]},
            "status": {"type": ["string", "null"]},
            "priority": {"type": ["string", "null"], "enum": ["low", "normal", "high", "urgent", null]},
            "created_from": {"type": ["string", "null"], "format": "date-time"},
            "created_to": {"type": ["string", "null"], "format": "date-time"},
            "page": {"type": "integer", "minimum": 1, "default": 1},
            "page_size": {"type": "integer", "minimum": 1, "maximum": 100, "default": 20}
          }
        }
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool_name", "tool_version", "tenant_id", "trace_id", "status"],
      "properties": {
        "tool_name": {"type": "string", "const": "ticket.search.v1"},
        "tool_version": {"type": "string", "const": "v1"},
        "tenant_id": {"type": "string"},
        "trace_id": {"type": "string"},
        "status": {"type": "string", "enum": ["success", "failed"]},
        "output": {
          "type": ["object", "null"],
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["ticket_id", "title", "status", "priority"],
                "properties": {
                  "ticket_id": {"type": "string"},
                  "title": {"type": "string"},
                  "status": {"type": "string"},
                  "priority": {"type": "string"}
                }
              }
            },
            "page": {"type": "integer"},
            "page_size": {"type": "integer"},
            "total": {"type": "integer"}
          }
        },
        "error": {"type": ["object", "null"]}
      }
    }
  }
}
