{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentops-hub.local/contracts/events/agent.run.started.v1.schema.json",
  "title": "agent.run.started.v1",
  "type": "object",
  "x_producer": "agent-service",
  "x_consumers": ["java-task-entrypoint", "web-console-stream"],
  "x_compatibility": "Additive payload fields are compatible within v1.",
  "additionalProperties": false,
  "required": ["event_id", "event_name", "event_version", "occurred_at", "tenant_id", "trace_id", "producer", "consumers", "payload"],
  "properties": {
    "event_id": {"type": "string"},
    "event_name": {"type": "string", "const": "agent.run.started.v1"},
    "event_version": {"type": "string", "const": "v1"},
    "occurred_at": {"type": "string", "format": "date-time"},
    "tenant_id": {"type": "string"},
    "trace_id": {"type": "string"},
    "producer": {"type": "string", "const": "agent-service"},
    "consumers": {"type": "array", "items": {"type": "string"}},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "run_id", "graph_name", "graph_version", "status", "started_at"],
      "properties": {
        "task_id": {"type": "string"},
        "run_id": {"type": "string"},
        "graph_name": {"type": "string"},
        "graph_version": {"type": "string"},
        "status": {"type": "string", "const": "started"},
        "started_at": {"type": "string", "format": "date-time"}
      }
    }
  }
}
