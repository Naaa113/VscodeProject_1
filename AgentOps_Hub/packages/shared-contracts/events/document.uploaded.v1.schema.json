{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentops-hub.local/contracts/events/document.uploaded.v1.schema.json",
  "title": "document.uploaded.v1",
  "type": "object",
  "x_producer": "document-entrypoint",
  "x_consumers": ["rag-service"],
  "x_compatibility": "Additive payload fields are compatible within v1.",
  "additionalProperties": false,
  "required": ["event_id", "event_name", "event_version", "occurred_at", "tenant_id", "trace_id", "producer", "consumers", "payload"],
  "properties": {
    "event_id": {"type": "string"},
    "event_name": {"type": "string", "const": "document.uploaded.v1"},
    "event_version": {"type": "string", "const": "v1"},
    "occurred_at": {"type": "string", "format": "date-time"},
    "tenant_id": {"type": "string"},
    "trace_id": {"type": "string"},
    "producer": {"type": "string", "const": "document-entrypoint"},
    "consumers": {"type": "array", "items": {"type": "string"}, "contains": {"const": "rag-service"}},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document_id", "knowledge_base_id", "tenant_id", "object_key", "filename", "parse_status"],
      "properties": {
        "document_id": {"type": "string"},
        "knowledge_base_id": {"type": "string"},
        "tenant_id": {"type": "string"},
        "object_key": {"type": "string"},
        "filename": {"type": "string"},
        "parse_status": {"type": "string", "const": "uploaded"}
      }
    }
  }
}
